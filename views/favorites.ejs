<%- include('partials/header', { title: 'My Bookmarks' }) %>
<%- include('partials/navbar') %>

<div class="container mt-5 mb-5 pb-4" style="min-height: 70vh;">
    <div class="row">
        <div class="col-12 mb-4">
            <h2 style="font-weight: 800; color: #0f172a;">
                <i class="fa-solid fa-star text-warning me-2"></i> Bookmarked Articles
            </h2>
            <p class="text-muted">The stories you've saved to read later.</p>
        </div>
    </div>

    <% if (articles && articles.length > 0) { %>
        <div class="row g-4">
            <% articles.forEach(article => { %>
                <div class="col-md-6 col-lg-4 article-card-wrapper" id="article-<%= article._id %>">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 16px; overflow: hidden; background: #fff; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                        <div style="position: relative;">
                            <img src="<%= article.urlToImage %>"
                                 onerror="this.onerror=null; this.src='https://placehold.co/600x400?text=News';"
                                 class="card-img-top"
                                 style="height: 200px; object-fit: cover;"
                                 alt="<%= article.title %>">

                            <button class="btn fav-card-toggle" data-id="<%= article._id %>" style="position: absolute; top: 12px; right: 12px; background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.15); transition: transform 0.2s ease;">
                                <i class="fa-solid fa-star" style="color: #ffc107; font-size: 1.1rem;"></i>
                            </button>
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <span class="badge bg-light text-primary align-self-start mb-2" style="font-weight: 600; border-radius: 6px;"><%= article.source?.name || 'News' %></span>
                            <h5 class="card-title" style="font-weight: 700; line-height: 1.4; color: #1e293b;"><%= article.title %></h5>
                            <p class="card-text text-muted small mt-2 flex-grow-1"><%= article.description ? article.description.substring(0, 100) + '...' : '' %></p>
                            <a href="/news/<%= article._id %>" class="btn btn-outline-primary w-100 mt-3" style="border-radius: 10px; font-weight: 600;">Read Article</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div class="pagination-wrapper mt-5">
                <nav aria-label="Page navigation">
                    <ul class="pagination premium-pagination-nodes justify-content-center">

                        <li class="page-node <%= currentPage <= 1 ? 'disabled' : '' %>">
                            <a href="<%= currentPage <= 1 ? '#' : '/auth/favorites?page=' + (currentPage - 1) %>" class="node-link">
                                <i class="fa-solid fa-arrow-left-long me-2"></i> Previous
                            </a>
                        </li>

                        <% paginationRange.forEach(i => { %>
                            <% if (i === '...') { %>
                                <li class="page-node interactive-dots">
                                    <input type="number" class="dots-input" value="..." placeholder="..." min="1" max="<%= totalPages %>"
                                           onfocus="this.value=''" onblur="if(this.value=='') this.value='...'"
                                           onkeydown="if(event.key === 'Enter' && this.value) { window.location.href = '/auth/favorites?page=' + this.value; }">
                                </li>
                            <% } else { %>
                                <li class="page-node <%= currentPage === i ? 'active' : '' %>">
                                    <a href="/auth/favorites?page=<%= i %>" class="node-link">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } %>
                        <% }) %>

                        <li class="page-node <%= currentPage >= totalPages ? 'disabled' : '' %>">
                            <a href="<%= currentPage >= totalPages ? '#' : '/auth/favorites?page=' + (currentPage + 1) %>" class="node-link">
                                Next <i class="fa-solid fa-arrow-right-long ms-2"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        <% } %>

    <% } else { %>
        <div class="text-center py-5 mt-5">
            <div class="mb-4">
                <i class="fa-regular fa-star fa-4x opacity-25" style="color: #64748b;"></i>
            </div>
            <h4 style="font-weight: 700; color: #334155;">No saved articles yet</h4>
            <p class="text-muted">Tap the star icon on any article to save it here.</p>
            <a href="/" class="btn btn-primary mt-3 px-4 py-2" style="border-radius: 12px; font-weight: 600;">Browse News</a>
        </div>
    <% } %>
</div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const favButtons = document.querySelectorAll('.fav-card-toggle');
        favButtons.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                const articleId = btn.dataset.id;
                const cardWrapper = document.getElementById(`article-${articleId}`);
                btn.style.transform = 'scale(0.8)';
                try {
                    const response = await fetch(`/auth/favorites/toggle/${articleId}`, { method: 'POST' });
                    const data = await response.json();
                    if (data.success && !data.isAdded) {
                        cardWrapper.style.transition = 'all 0.3s ease';
                        cardWrapper.style.opacity = '0';
                        setTimeout(() => {
                            cardWrapper.remove();
                            if (document.querySelectorAll('.article-card-wrapper').length === 0) window.location.reload();
                        }, 300);
                    }
                } catch (err) {
                    btn.style.transform = 'scale(1)';
                    console.error(err);
                }
            });
        });
    });
</script>

<%- include('partials/footer') %>